# Main backend API base URL (no trailing slash). Used by src/lib/config/api.ts
NEXT_PUBLIC_API_URL=http://localhost:5103

# Optional: legacy name when NEXT_PUBLIC_API_URL is unset
# NEXT_PUBLIC_API_BASE_URL=http://localhost:5103

# Flask resume parser — proxied by Next at /api/resume-parse (appends /api/parse-resume)
# Local default when unset in development: http://127.0.0.1:5000
NEXT_PUBLIC_PARSER_API_URL=http://127.0.0.1:5000
# RESUME_PARSER_URL=http://127.0.0.1:5000

# Optional: questions proxy (src/app/api/generate-questions/route.ts)
# QUESTIONS_API_URL=http://localhost:8002
